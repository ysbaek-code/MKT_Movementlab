#!/usr/bin/env python3
"""
projects.csv + categories.csv + costs.csv -> summary.md

- projects.csv   : 프로젝트명,시작일,종료일,총예산,담당자,상태
- categories.csv : 프로젝트명,카테고리
    프로젝트마다 사용할 비용 카테고리를 정의하는 파일. 프로젝트별로 항목이 다 달라도 됨.
    카테고리를 추가/삭제/이름변경 하고 싶으면 이 파일을 직접 편집하면 됨
    (같은 프로젝트명에 여러 행을 추가해서 카테고리를 여러 개 정의).
- costs.csv      : 프로젝트명,카테고리,항목,금액,날짜,상태,비고
    실제 지출 한 건씩 기록. 카테고리는 자유 텍스트지만, categories.csv에 정의된
    이름과 철자가 같아야 교차표/집계에 정확히 반영됨.

실행: python3 summarize.py
아무 CSV나 수정한 뒤 다시 실행하면 summary.md가 최신 내용으로 갱신됩니다.
"""
import csv
from pathlib import Path
from collections import defaultdict

BASE = Path(__file__).parent

def load_csv(name):
    path = BASE / name
    with open(path, encoding="utf-8") as f:
        return list(csv.DictReader(f))

def to_num(v):
    try:
        return float(str(v).replace(",", "").strip() or 0)
    except ValueError:
        return 0

def fmt(n):
    return f"{n:,.0f}원"

def main():
    projects = load_csv("projects.csv")
    categories = load_csv("categories.csv")
    costs = load_csv("costs.csv")

    proj_order = [p["프로젝트명"] for p in projects]
    proj_budget = {p["프로젝트명"]: to_num(p.get("총예산")) for p in projects}
    status_map = {p["프로젝트명"]: p.get("상태", "") for p in projects}

    # 프로젝트별 정의된 카테고리 (순서 보존)
    proj_categories = defaultdict(list)
    for row in categories:
        proj = row["프로젝트명"].strip()
        cat = row["카테고리"].strip()
        if cat not in proj_categories[proj]:
            proj_categories[proj].append(cat)

    # 교차표에 쓸 전체 카테고리 순서 (categories.csv 등장 순서 기준)
    cat_order = []
    for row in categories:
        cat = row["카테고리"].strip()
        if cat not in cat_order:
            cat_order.append(cat)

    # matrix[project][category] = sum
    matrix = defaultdict(lambda: defaultdict(float))
    proj_total = defaultdict(float)
    cat_total = defaultdict(float)
    unknown_projects = []
    undefined_cat_issues = []  # (project, category) 조합이 categories.csv에 없는 경우

    for c in costs:
        proj = c["프로젝트명"].strip()
        cat = c["카테고리"].strip()
        amt = to_num(c["금액"])
        matrix[proj][cat] += amt
        proj_total[proj] += amt
        cat_total[cat] += amt
        if cat not in cat_order:
            cat_order.append(cat)
        if proj not in proj_order and proj not in unknown_projects:
            unknown_projects.append(proj)
        if proj in proj_categories and cat not in proj_categories[proj]:
            if (proj, cat) not in undefined_cat_issues:
                undefined_cat_issues.append((proj, cat))

    all_projects = proj_order + unknown_projects
    grand_total = sum(proj_total.values())

    lines = []
    lines.append("# 비용 요약\n")
    lines.append("(projects.csv / categories.csv / costs.csv 로부터 자동 생성 — 수정 후 `python3 summarize.py` 재실행)\n")

    # 0. 프로젝트별 정의된 카테고리
    lines.append("## 프로젝트별 비용 카테고리 정의\n")
    lines.append("(categories.csv 를 편집하면 여기가 바뀝니다)\n")
    lines.append("| 프로젝트 | 정의된 카테고리 |")
    lines.append("|---|---|")
    for proj in all_projects:
        cats = proj_categories.get(proj, [])
        lines.append(f"| {proj} | {', '.join(cats) if cats else '(미정의 — categories.csv에 추가 필요)'} |")
    lines.append("")

    # 1. 프로젝트별 합계
    lines.append("## 프로젝트별 집행액\n")
    lines.append("| 프로젝트 | 총예산 | 집행액 | 집행률 | 상태 |")
    lines.append("|---|---|---|---|---|")
    for proj in all_projects:
        budget = proj_budget.get(proj, 0)
        spent = proj_total.get(proj, 0)
        rate = f"{spent/budget*100:.1f}%" if budget else "-"
        budget_s = fmt(budget) if budget else "-"
        lines.append(f"| {proj} | {budget_s} | {fmt(spent)} | {rate} | {status_map.get(proj,'-')} |")
    lines.append(f"| **합계** | | **{fmt(grand_total)}** | | |\n")

    # 2. 카테고리별 합계
    lines.append("## 카테고리별 집행액 (전체 프로젝트 통합)\n")
    lines.append("| 카테고리 | 금액 | 비중 |")
    lines.append("|---|---|---|")
    for cat in sorted(cat_total, key=lambda c: -cat_total[c]):
        amt = cat_total[cat]
        pct = f"{amt/grand_total*100:.1f}%" if grand_total else "-"
        lines.append(f"| {cat} | {fmt(amt)} | {pct} |")
    lines.append("")

    # 3. 프로젝트 x 카테고리 교차표
    # 셀 표시 규칙: 그 프로젝트에 정의된 카테고리가 아니면 "-" (해당 없음),
    # 정의되어 있으면 지출이 0이어도 0원으로 표시
    lines.append("## 프로젝트 x 카테고리 교차표\n")
    lines.append("(\"-\" = 해당 프로젝트에 정의되지 않은 카테고리)\n")
    header = "| 프로젝트 | " + " | ".join(cat_order) + " | 합계 |"
    sep = "|---" * (len(cat_order) + 2) + "|"
    lines.append(header)
    lines.append(sep)
    for proj in all_projects:
        row = [proj]
        defined = proj_categories.get(proj, [])
        for cat in cat_order:
            v = matrix[proj].get(cat, 0)
            if v:
                row.append(fmt(v))
            elif defined and cat in defined:
                row.append(fmt(0))
            elif not defined:
                row.append("-")
            else:
                row.append("-")
        row.append(fmt(proj_total.get(proj, 0)))
        lines.append("| " + " | ".join(row) + " |")
    cat_row = ["**카테고리 합계**"]
    for cat in cat_order:
        cat_row.append(fmt(cat_total.get(cat, 0)))
    cat_row.append(fmt(grand_total))
    lines.append("| " + " | ".join(cat_row) + " |")

    warnings = []
    if unknown_projects:
        warnings.append("⚠️ projects.csv에 없는 프로젝트명이 costs.csv에서 발견됨: "
                         + ", ".join(unknown_projects) + " (오타 여부 확인 필요)")
    if undefined_cat_issues:
        detail = ", ".join(f"{p}→{c}" for p, c in undefined_cat_issues)
        warnings.append("⚠️ categories.csv에 정의되지 않은 카테고리가 costs.csv에서 사용됨: "
                         + detail + " (오타이거나, categories.csv에 새 카테고리 추가 필요)")
    if warnings:
        lines.append("")
        for w in warnings:
            lines.append(f"> {w}")

    out = "\n".join(lines) + "\n"
    (BASE / "summary.md").write_text(out, encoding="utf-8")
    print(out)

if __name__ == "__main__":
    main()
