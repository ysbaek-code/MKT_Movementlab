
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>콘텐츠 캘린더 — Movement Lab</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#f7f6f3;--surface:#fff;--surface2:#f0efe9;
  --text:#1a1a18;--text2:#52514e;--muted:#999894;
  --border:rgba(0,0,0,0.08);--border-strong:rgba(0,0,0,0.15);
  --radius:8px;
  --accent:#2a78d6;--accent-bg:#e6f1fb;
  --success:#1baf7a;--warning:#e09000;--danger:#e24b4a;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;min-height:100vh;}
.header{background:var(--surface);border-bottom:0.5px solid var(--border);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:100;}
.header-left{display:flex;align-items:center;gap:16px;}
.logo{font-size:13px;font-weight:600;color:var(--text2);}
.logo span{color:var(--text);font-weight:700;}
.view-tabs{display:flex;gap:2px;background:var(--surface2);border-radius:6px;padding:3px;}
.view-tab{background:none;border:none;padding:5px 12px;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;border-radius:4px;font-family:inherit;}
.view-tab.active{background:var(--surface);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.08);}
.header-right{display:flex;gap:8px;}
.btn{cursor:pointer;font-family:inherit;font-size:13px;padding:7px 13px;border-radius:var(--radius);font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all .15s;white-space:nowrap;border:none;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{opacity:.88;}
.btn-ghost{background:transparent;border:0.5px solid var(--border-strong);color:var(--text2);}
.btn-ghost:hover{background:var(--surface2);}
.btn-sm{padding:5px 10px;font-size:12px;}
.filter-bar{padding:.875rem 2rem;background:var(--surface);border-bottom:0.5px solid var(--border);display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.filter-bar select,.filter-bar input[type=month]{font-size:12px;padding:5px 9px;border-radius:var(--radius);border:0.5px solid var(--border-strong);background:var(--surface);color:var(--text);cursor:pointer;font-family:inherit;}
.filter-sep{width:1px;height:18px;background:var(--border-strong);margin:0 4px;}
.filter-label{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.05em;}
.main{padding:1.5rem 2rem;}

/* 캘린더 */
.cal-header{display:flex;align-items:center;gap:12px;margin-bottom:1.25rem;}
.cal-nav{display:flex;gap:4px;}
.cal-nav button{background:var(--surface);border:0.5px solid var(--border-strong);color:var(--text2);width:30px;height:30px;border-radius:var(--radius);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;}
.cal-nav button:hover{background:var(--surface2);}
.cal-month-label{font-size:17px;font-weight:600;min-width:110px;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--border);border:0.5px solid var(--border);border-radius:10px;overflow:hidden;}
.cal-day-header{background:var(--surface2);padding:7px 10px;font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;text-align:center;}
.cal-day-header:first-child{color:var(--danger);}
.cal-day-header:last-child{color:var(--accent);}
.cal-cell{background:var(--surface);min-height:100px;padding:6px 8px;cursor:pointer;transition:background .1s;}
.cal-cell:hover{background:#fafaf7;}
.cal-cell.other-month .cal-date{color:var(--muted);}
.cal-cell.today .cal-date{background:var(--accent);color:#fff;border-radius:50%;}
.cal-cell.sunday .cal-date{color:var(--danger);}
.cal-cell.saturday .cal-date{color:var(--accent);}
.cal-date{font-size:12px;font-weight:500;width:22px;height:22px;display:flex;align-items:center;justify-content:center;margin-bottom:4px;}
.cal-items{display:flex;flex-direction:column;gap:2px;}
.cal-item{font-size:10px;padding:2px 5px;border-radius:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;line-height:1.4;}

/* 리스트 — 콘텐츠 그룹 */
.content-group{background:var(--surface);border:0.5px solid var(--border);border-radius:12px;margin-bottom:12px;overflow:hidden;}
.content-group-header{padding:14px 16px;display:grid;grid-template-columns:90px 1fr auto;gap:12px;align-items:start;cursor:pointer;transition:background .1s;}
.content-group-header:hover{background:#fafaf7;}
.cg-date .day{font-size:22px;font-weight:700;color:var(--text);line-height:1;}
.cg-date .dow{font-size:12px;color:var(--muted);}
.cg-body{}
.cg-title{font-size:14px;font-weight:600;color:var(--text);margin-bottom:6px;}
.cg-meta{display:flex;gap:6px;flex-wrap:wrap;align-items:center;}
.cg-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;}
/* 채널 행 테이블 */
.channel-rows{border-top:0.5px solid var(--border);}
.channel-row{display:grid;grid-template-columns:36px 110px 1fr 110px 130px 80px 36px;gap:0;align-items:center;border-bottom:0.5px solid var(--border);font-size:13px;}
.channel-row:last-child{border-bottom:none;}
.channel-row:hover{background:var(--surface2);}
.cr-cell{padding:10px 12px;}
.cr-indent{background:var(--surface2);width:36px;height:100%;display:flex;align-items:center;justify-content:center;}
.cr-channel{font-weight:500;}
.cr-owner{color:var(--text2);font-size:12px;}
.cr-link a{color:var(--accent);font-size:12px;text-decoration:none;}
.cr-link a:hover{text-decoration:underline;}
.cr-memo{color:var(--text2);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;}
.cr-actions{display:flex;gap:4px;justify-content:flex-end;}
.cr-edit-btn{background:none;border:none;cursor:pointer;color:var(--muted);padding:3px 6px;border-radius:4px;font-size:12px;}
.cr-edit-btn:hover{background:var(--accent-bg);color:var(--accent);}
.ch-header{display:grid;grid-template-columns:36px 110px 1fr 110px 130px 80px 36px;background:var(--surface2);border-top:0.5px solid var(--border);font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.04em;}
.ch-header-cell{padding:6px 12px;}
.add-channel-btn{padding:8px 16px;font-size:12px;color:var(--accent);background:none;border:none;cursor:pointer;font-family:inherit;width:100%;text-align:left;border-top:0.5px solid var(--border);}
.add-channel-btn:hover{background:var(--accent-bg);}

/* 배지 */
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:4px;font-size:11px;font-weight:500;white-space:nowrap;}
.ch-insta{background:#fce4ec;color:#ad1457;}
.ch-blog{background:#fff3e0;color:#e65100;}
.ch-journal{background:#e8eaf6;color:#283593;}
.th-curation{background:#E1F5EE;color:#0a5a43;}
.th-selected{background:#EEEDFE;color:#3f348f;}
.th-clubmovement{background:#FAEEDA;color:#7a4a08;}
.th-showroom{background:#E6F1FB;color:#144f8a;}
.th-newitem{background:#FBEAF0;color:#7a1f45;}
.th-preview{background:#FAECE7;color:#7a2e10;}
.th-promotion{background:#F3F2EF;color:#4a4a48;}
.th-theusers{background:#EAF3DE;color:#2d5a0d;}
.th-clubmovementhome{background:#FFF8E1;color:#7a5800;}
.th-other{background:#F3F2EF;color:#4a4a48;}
.st-planning{background:#f3f2ef;color:#52514e;}
.st-creating{background:#fff3cd;color:#856404;}
.st-published{background:#d1f5e5;color:#0a5a43;}

/* 모달 */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:300;align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal{background:var(--surface);border-radius:14px;padding:1.5rem;width:min(560px,95vw);max-height:90vh;overflow-y:auto;box-shadow:0 12px 48px rgba(0,0,0,.18);}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;}
.modal-header h2{font-size:16px;font-weight:600;}
.modal-close{background:none;border:none;font-size:18px;color:var(--muted);cursor:pointer;padding:2px 8px;border-radius:4px;}
.modal-close:hover{background:var(--surface2);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.form-full{grid-column:1/-1;}
.fg{display:flex;flex-direction:column;gap:4px;}
.fg label{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.04em;}
.fg input,.fg select,.fg textarea{font-size:13px;padding:7px 10px;border:0.5px solid var(--border-strong);border-radius:var(--radius);background:var(--surface2);color:var(--text);font-family:inherit;width:100%;}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--accent);}
.fg textarea{resize:vertical;min-height:60px;}
.section-divider{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;padding:14px 0 8px;border-bottom:0.5px solid var(--border);margin-bottom:10px;grid-column:1/-1;}
.modal-footer{display:flex;justify-content:space-between;align-items:center;margin-top:1.25rem;gap:8px;}
.modal-footer-right{display:flex;gap:8px;}
.btn-danger-ghost{background:transparent;border:0.5px solid var(--danger);color:var(--danger);cursor:pointer;font-family:inherit;font-size:12px;padding:5px 10px;border-radius:var(--radius);}

.toast{position:fixed;bottom:24px;right:24px;background:var(--text);color:var(--bg);padding:10px 16px;border-radius:var(--radius);font-size:13px;font-weight:500;opacity:0;transform:translateY(6px);transition:all .25s;pointer-events:none;z-index:999;}
.toast.show{opacity:1;transform:translateY(0);}
.empty{text-align:center;padding:3rem 1rem;color:var(--muted);font-size:13px;}

@media(max-width:700px){
  .header{padding:0 1rem;}.main{padding:1rem;}.filter-bar{padding:.75rem 1rem;}
  .channel-row{grid-template-columns:28px 90px 1fr 80px;}.cr-link,.cr-memo,.cr-owner{display:none;}
  .ch-header{grid-template-columns:28px 90px 1fr 80px;}
  .form-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<header class="header">
  <div class="header-left">
    <div class="logo"><span>Movement Lab</span> · 콘텐츠 캘린더</div>
    <div class="view-tabs">
      <button class="view-tab active" onclick="switchView('calendar',this)">📅 캘린더</button>
      <button class="view-tab" onclick="switchView('list',this)">📋 리스트</button>
    </div>
  </div>
  <div class="header-right">
    <button class="btn btn-ghost btn-sm" onclick="exportCSV()">CSV</button>
    <button class="btn btn-primary btn-sm" onclick="openContentModal()">+ 콘텐츠 추가</button>
  </div>
</header>

<div class="filter-bar">
  <span class="filter-label">필터</span>
  <select id="filterChannel" onchange="applyFilters()">
    <option value="">전체 채널</option>
    <option value="insta">인스타그램</option>
    <option value="blog">블로그</option>
    <option value="journal">저널</option>
  </select>
  <select id="filterTheme" onchange="applyFilters()">
    <option value="">전체 테마</option>
    <option value="curation">curation</option>
    <option value="selected">selected</option>
    <option value="club movement">club movement</option>
    <option value="showroom">showroom / 팝업</option>
    <option value="new item">new item / item</option>
    <option value="preview">preview</option>
    <option value="promotion">promotion</option>
    <option value="the users">the users</option>
    <option value="club movement home">Club Movement Home</option>
    <option value="기타">기타</option>
  </select>
  <select id="filterStatus" onchange="applyFilters()">
    <option value="">전체 상태</option>
    <option value="planning">기획중</option>
    <option value="creating">제작중</option>
    <option value="published">발행완료</option>
  </select>
  <select id="filterOwner" onchange="applyFilters()">
    <option value="">전체 담당자</option>
  </select>
  <div class="filter-sep"></div>
  <input type="month" id="filterMonth" onchange="applyFilters()">
</div>

<!-- 캘린더 뷰 -->
<div id="view-calendar" class="main">
  <div class="cal-header">
    <div class="cal-nav">
      <button onclick="calPrev()">‹</button>
      <button onclick="calToday()">오늘</button>
      <button onclick="calNext()">›</button>
    </div>
    <div class="cal-month-label" id="calLabel"></div>
  </div>
  <div class="cal-grid" id="calGrid"></div>
</div>

<!-- 리스트 뷰 -->
<div id="view-list" class="main" style="display:none;">
  <div id="listView"></div>
</div>

<!-- 콘텐츠 추가/수정 모달 -->
<div class="modal-bg" id="contentModal">
  <div class="modal">
    <div class="modal-header">
      <h2 id="contentModalTitle">콘텐츠 추가</h2>
      <button class="modal-close" onclick="closeModal('contentModal')">✕</button>
    </div>
    <div class="form-grid">
      <div class="fg form-full"><label>콘텐츠 제목</label><input type="text" id="cm_title" placeholder="제목을 입력하세요"></div>
      <div class="fg"><label>발행일</label><input type="date" id="cm_date"></div>
      <div class="fg"><label>테마</label>
        <select id="cm_theme">
          <option value="curation">curation</option>
          <option value="selected">selected</option>
          <option value="club movement">club movement</option>
          <option value="showroom">showroom / 팝업</option>
          <option value="new item">new item / item</option>
          <option value="preview">preview</option>
          <option value="promotion">promotion</option>
          <option value="the users">the users</option>
          <option value="club movement home">Club Movement Home</option>
          <option value="기타">기타</option>
        </select>
      </div>
      <div class="fg form-full"><label>연관 브랜드 / 제품</label><input type="text" id="cm_brand" placeholder="예: 오블리크테이블, Nua 파우더 블루 체어"></div>
    </div>
    <div class="modal-footer">
      <div id="cm_deleteBtn" style="display:none;"><button class="btn-danger-ghost" onclick="deleteContent()">삭제</button></div>
      <div class="modal-footer-right">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('contentModal')">취소</button>
        <button class="btn btn-primary btn-sm" id="cm_saveBtn" onclick="saveContent()">저장</button>
      </div>
    </div>
  </div>
</div>

<!-- 채널 행 추가/수정 모달 -->
<div class="modal-bg" id="channelModal">
  <div class="modal">
    <div class="modal-header">
      <h2 id="channelModalTitle">채널 추가</h2>
      <button class="modal-close" onclick="closeModal('channelModal')">✕</button>
    </div>
    <div style="font-size:12px;color:var(--muted);margin-bottom:14px;" id="channelModalSub"></div>
    <div class="form-grid">
      <div class="fg"><label>노출 채널</label>
        <select id="chm_channel">
          <option value="insta">📷 인스타그램</option>
          <option value="blog">✍️ 블로그</option>
          <option value="journal">📖 저널</option>
        </select>
      </div>
      <div class="fg"><label>상태</label>
        <select id="chm_status">
          <option value="planning">기획중</option>
          <option value="creating">제작중</option>
          <option value="published">발행완료</option>
        </select>
      </div>
      <div class="fg"><label>담당자</label><input type="text" id="chm_owner" placeholder="이름 입력"></div>
      <div class="fg form-full"><label>링크 URL</label><input type="url" id="chm_link" placeholder="발행 후 URL (블로그, 저널, 인스타 게시물)"></div>
      <div class="fg form-full"><label>메모</label><textarea id="chm_memo" placeholder="채널별 팔로업 메모 — MD팀 제품 추가 노출 요청, 성과 기록 등"></textarea></div>
    </div>
    <div class="modal-footer">
      <div id="chm_deleteBtn" style="display:none;"><button class="btn-danger-ghost" onclick="deleteChannelRow()">삭제</button></div>
      <div class="modal-footer-right">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('channelModal')">취소</button>
        <button class="btn btn-primary btn-sm" onclick="saveChannelRow()">저장</button>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const LS_KEY = 'ml_content_v2';
// contents: [{id, title, date, theme, brand, channels:[{id, channel, status, owner, link, memo}]}]
let contents = [];
let editContentId = null;
let editChannelContentId = null;
let editChannelId = null;
let calYear, calMonth;

const THEMES = {
  'curation':'th-curation','selected':'th-selected','club movement':'th-clubmovement',
  'showroom':'th-showroom','new item':'th-newitem','preview':'th-preview',
  'promotion':'th-promotion','the users':'th-theusers','club movement home':'th-clubmovementhome','기타':'th-other'
};
const THEME_LABELS = {
  'curation':'curation','selected':'selected','club movement':'club movement',
  'showroom':'showroom / 팝업','new item':'new item / item','preview':'preview',
  'promotion':'promotion','the users':'the users','club movement home':'Club Movement Home','기타':'기타'
};
const CH_LABELS = {'insta':'📷 인스타그램','blog':'✍️ 블로그','journal':'📖 저널'};
const CH_CLS = {'insta':'ch-insta','blog':'ch-blog','journal':'ch-journal'};
const ST_LABELS = {'planning':'기획중','creating':'제작중','published':'발행완료'};
const ST_CLS = {'planning':'st-planning','creating':'st-creating','published':'st-published'};

// ── 저장/불러오기 ──
function save(){
  localStorage.setItem(LS_KEY, JSON.stringify(contents));
  updateOwnerFilter();
}
function load(){
  try{ const d=localStorage.getItem(LS_KEY); if(d) contents=JSON.parse(d); }catch(e){ contents=[]; }
  if(!contents.length) contents=sampleData();
}
function sampleData(){
  const today=new Date(), y=today.getFullYear(), m=String(today.getMonth()+1).padStart(2,'0');
  return [
    {id:1,title:'모서리를 없앤 라운드 사이드 테이블',date:`${y}-${m}-03`,theme:'curation',brand:'바이헤이데이',channels:[
      {id:11,channel:'insta',status:'published',owner:'영실',link:'',memo:''},
      {id:12,channel:'blog',status:'published',owner:'영실',link:'https://blog.naver.com',memo:''},
    ]},
    {id:2,title:'국밥만큼 맛있는 부산 미식 공간',date:`${y}-${m}-07`,theme:'club movement',brand:'',channels:[
      {id:21,channel:'insta',status:'published',owner:'영실',link:'',memo:'저장수 높음 — MD팀 팔로업 요청'},
      {id:22,channel:'blog',status:'creating',owner:'지수',link:'',memo:'원고 작성 중'},
    ]},
    {id:3,title:'무브먼트랩 팝업 OPEN',date:`${y}-${m}-10`,theme:'showroom',brand:'',channels:[
      {id:31,channel:'insta',status:'published',owner:'영실',link:'',memo:''},
      {id:32,channel:'journal',status:'planning',owner:'지수',link:'',memo:'사진 촬영 후 업로드 예정'},
    ]},
    {id:4,title:'The Craft of Knotting',date:`${y}-${m}-18`,theme:'new item',brand:'오블리크테이블',channels:[
      {id:41,channel:'insta',status:'creating',owner:'영실',link:'',memo:'제품 사진 수령 후 제작'},
      {id:42,channel:'journal',status:'planning',owner:'지수',link:'',memo:'MD팀 제품 리스트 확인 요청'},
    ]},
    {id:5,title:'Club Movement Home 리뷰',date:`${y}-${m}-24`,theme:'club movement home',brand:'',channels:[
      {id:51,channel:'blog',status:'planning',owner:'지수',link:'',memo:''},
    ]},
  ];
}

// ── 필터 ──
function getFilters(){
  return {
    ch: document.getElementById('filterChannel').value,
    th: document.getElementById('filterTheme').value,
    st: document.getElementById('filterStatus').value,
    ow: document.getElementById('filterOwner').value,
    mo: document.getElementById('filterMonth').value,
  };
}
function contentPassesFilter(c, f){
  if(f.th && c.theme !== f.th) return false;
  if(f.mo && !c.date.startsWith(f.mo)) return false;
  if(f.ch || f.st || f.ow){
    const matchingCh = c.channels.filter(ch=>{
      if(f.ch && ch.channel !== f.ch) return false;
      if(f.st && ch.status !== f.st) return false;
      if(f.ow && ch.owner !== f.ow) return false;
      return true;
    });
    return matchingCh.length > 0;
  }
  return true;
}
function filteredChannels(c, f){
  return c.channels.filter(ch=>{
    if(f.ch && ch.channel !== f.ch) return false;
    if(f.st && ch.status !== f.st) return false;
    if(f.ow && ch.owner !== f.ow) return false;
    return true;
  });
}
function applyFilters(){ renderCurrent(); }
function updateOwnerFilter(){
  const owners=[...new Set(contents.flatMap(c=>c.channels.map(ch=>ch.owner)).filter(Boolean))].sort();
  const sel=document.getElementById('filterOwner'), cur=sel.value;
  sel.innerHTML='<option value="">전체 담당자</option>'+owners.map(o=>`<option value="${o}">${o}</option>`).join('');
  if(cur) sel.value=cur;
}

// ── 뷰 전환 ──
let currentView='calendar';
function switchView(v, el){
  currentView=v;
  document.getElementById('view-calendar').style.display=v==='calendar'?'':'none';
  document.getElementById('view-list').style.display=v==='list'?'':'none';
  document.querySelectorAll('.view-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
  renderCurrent();
}
function renderCurrent(){ currentView==='calendar'?renderCalendar():renderList(); }

// ── 캘린더 ──
function initCal(){ const n=new Date(); calYear=n.getFullYear(); calMonth=n.getMonth(); }
function calPrev(){ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); }
function calNext(){ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); }
function calToday(){ const n=new Date(); calYear=n.getFullYear(); calMonth=n.getMonth(); renderCalendar(); }

function renderCalendar(){
  const months=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  document.getElementById('calLabel').textContent=`${calYear}년 ${months[calMonth]}`;
  const grid=document.getElementById('calGrid');
  const today=new Date(), first=new Date(calYear,calMonth,1), last=new Date(calYear,calMonth+1,0);
  const startDow=first.getDay();
  const monthStr=`${calYear}-${String(calMonth+1).padStart(2,'0')}`;
  const f=getFilters();
  const relevant=contents.filter(c=>c.date.startsWith(monthStr)&&contentPassesFilter(c,f));
  const days=['일','월','화','수','목','금','토'];
  let html=days.map(d=>`<div class="cal-day-header">${d}</div>`).join('');
  const prevLast=new Date(calYear,calMonth,0).getDate();
  for(let i=startDow-1;i>=0;i--) html+=`<div class="cal-cell other-month"><div class="cal-date">${prevLast-i}</div></div>`;
  for(let d=1;d<=last.getDate();d++){
    const ds=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dow=new Date(calYear,calMonth,d).getDay();
    const isToday=today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;
    const items=relevant.filter(c=>c.date===ds);
    const cls=['cal-cell',isToday?'today':'',dow===0?'sunday':dow===6?'saturday':''].filter(Boolean).join(' ');
    html+=`<div class="${cls}" onclick="calCellClick('${ds}')">
      <div class="cal-date">${d}</div>
      <div class="cal-items">
        ${items.slice(0,3).map(c=>{
          const allChs=filteredChannels(c,f);
          const worstStatus=allChs.some(ch=>ch.status==='planning')?'planning':allChs.some(ch=>ch.status==='creating')?'creating':'published';
          const bg=worstStatus==='published'?'#d1f5e5':worstStatus==='creating'?'#fff3cd':'#f0efe9';
          const co=worstStatus==='published'?'#0a5a43':worstStatus==='creating'?'#856404':'#52514e';
          return `<div class="cal-item" style="background:${bg};color:${co};" onclick="event.stopPropagation();scrollToContent(${c.id})">${c.title}</div>`;
        }).join('')}
        ${items.length>3?`<div style="font-size:10px;color:var(--muted);padding:1px 5px;">+${items.length-3}개</div>`:''}
      </div>
    </div>`;
  }
  const totalCells=startDow+last.getDate();
  const remaining=totalCells%7===0?0:7-totalCells%7;
  for(let i=1;i<=remaining;i++) html+=`<div class="cal-cell other-month"><div class="cal-date">${i}</div></div>`;
  grid.innerHTML=html;
}

function calCellClick(ds){ openContentModal(null, ds); }
function scrollToContent(id){
  switchView('list', document.querySelectorAll('.view-tab')[1]);
  setTimeout(()=>{ const el=document.getElementById('cg_'+id); if(el) el.scrollIntoView({behavior:'smooth',block:'center'}); },100);
}

// ── 리스트 뷰 ──
function renderList(){
  const f=getFilters();
  let list=contents.filter(c=>contentPassesFilter(c,f)).sort((a,b)=>a.date.localeCompare(b.date));
  if(!list.length){ document.getElementById('listView').innerHTML='<div class="empty">조건에 맞는 콘텐츠가 없습니다</div>'; return; }

  // 월별 그룹
  const groups={};
  list.forEach(c=>{ const k=c.date.slice(0,7); if(!groups[k]) groups[k]=[]; groups[k].push(c); });
  const monthNames=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  let html='';
  Object.keys(groups).sort().forEach(key=>{
    const [y,m]=key.split('-');
    html+=`<div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin:0 0 10px;padding-bottom:6px;border-bottom:0.5px solid var(--border);">${y}년 ${monthNames[parseInt(m)-1]} · ${groups[key].length}개 콘텐츠</div>`;
    groups[key].forEach(c=>{
      const d=new Date(c.date), dow=['일','월','화','수','목','금','토'][d.getDay()];
      const chs=filteredChannels(c,f);
      html+=`<div class="content-group" id="cg_${c.id}">
        <div class="content-group-header">
          <div class="cg-date"><div class="day">${String(d.getDate()).padStart(2,'0')}</div><div class="dow">${dow}요일</div></div>
          <div class="cg-body">
            <div class="cg-title">${c.title||'(제목 없음)'}</div>
            <div class="cg-meta">
              <span class="badge ${THEMES[c.theme]||'th-other'}">${THEME_LABELS[c.theme]||c.theme}</span>
              ${c.brand?`<span style="font-size:11px;color:var(--muted);">· ${c.brand}</span>`:''}
            </div>
          </div>
          <div class="cg-right">
            <button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();openContentModal(${c.id})" style="font-size:11px;padding:4px 8px;">수정</button>
          </div>
        </div>
        <div class="channel-rows">
          <div class="ch-header">
            <div class="ch-header-cell"></div>
            <div class="ch-header-cell">채널</div>
            <div class="ch-header-cell">메모</div>
            <div class="ch-header-cell">담당자</div>
            <div class="ch-header-cell">링크</div>
            <div class="ch-header-cell">상태</div>
            <div class="ch-header-cell"></div>
          </div>
          ${chs.map(ch=>`
            <div class="channel-row">
              <div class="cr-cell cr-indent"><div style="width:2px;height:20px;background:var(--border-strong);border-radius:1px;"></div></div>
              <div class="cr-cell cr-channel"><span class="badge ${CH_CLS[ch.channel]||''}">${CH_LABELS[ch.channel]||ch.channel}</span></div>
              <div class="cr-cell cr-memo">${ch.memo||'—'}</div>
              <div class="cr-cell cr-owner">${ch.owner||'—'}</div>
              <div class="cr-cell cr-link">${ch.link?`<a href="${ch.link}" target="_blank">링크 ↗</a>`:'—'}</div>
              <div class="cr-cell"><span class="badge ${ST_CLS[ch.status]||'st-planning'}">${ST_LABELS[ch.status]||ch.status}</span></div>
              <div class="cr-cell cr-actions"><button class="cr-edit-btn" onclick="openChannelModal(${c.id},${ch.id})" title="수정">✎</button></div>
            </div>`).join('')}
          <button class="add-channel-btn" onclick="openChannelModal(${c.id},null)">+ 채널 추가</button>
        </div>
      </div>`;
    });
    html+='<div style="margin-bottom:24px;"></div>';
  });
  document.getElementById('listView').innerHTML=html;
}

// ── 콘텐츠 모달 ──
function openContentModal(id=null, preDate=null){
  editContentId=id;
  document.getElementById('contentModalTitle').textContent=id?'콘텐츠 수정':'콘텐츠 추가';
  document.getElementById('cm_saveBtn').textContent=id?'수정 저장':'저장';
  document.getElementById('cm_deleteBtn').style.display=id?'block':'none';
  if(id){
    const c=contents.find(x=>x.id===id);
    document.getElementById('cm_title').value=c.title||'';
    document.getElementById('cm_date').value=c.date||'';
    document.getElementById('cm_theme').value=c.theme||'curation';
    document.getElementById('cm_brand').value=c.brand||'';
  } else {
    document.getElementById('cm_title').value='';
    document.getElementById('cm_date').value=preDate||new Date().toISOString().slice(0,10);
    document.getElementById('cm_theme').value='curation';
    document.getElementById('cm_brand').value='';
  }
  document.getElementById('contentModal').classList.add('open');
}
function saveContent(){
  const title=document.getElementById('cm_title').value.trim();
  const date=document.getElementById('cm_date').value;
  if(!title){toast('제목을 입력해주세요',false);return;}
  if(!date){toast('발행일을 입력해주세요',false);return;}
  if(editContentId){
    const i=contents.findIndex(x=>x.id===editContentId);
    if(i>=0){ contents[i].title=title; contents[i].date=date; contents[i].theme=document.getElementById('cm_theme').value; contents[i].brand=document.getElementById('cm_brand').value.trim(); }
  } else {
    contents.push({id:Date.now(),title,date,theme:document.getElementById('cm_theme').value,brand:document.getElementById('cm_brand').value.trim(),channels:[]});
  }
  save();closeModal('contentModal');renderCurrent();
  toast(editContentId?'수정되었습니다':'추가되었습니다. 채널을 추가해주세요.');
}
function deleteContent(){
  if(!confirm('콘텐츠와 모든 채널 데이터를 삭제할까요?')) return;
  contents=contents.filter(x=>x.id!==editContentId);
  save();closeModal('contentModal');renderCurrent();toast('삭제됨');
}

// ── 채널 모달 ──
function openChannelModal(contentId, channelId=null){
  editChannelContentId=contentId;
  editChannelId=channelId;
  const c=contents.find(x=>x.id===contentId);
  document.getElementById('channelModalTitle').textContent=channelId?'채널 수정':'채널 추가';
  document.getElementById('channelModalSub').textContent=c?c.title:'';
  document.getElementById('chm_deleteBtn').style.display=channelId?'block':'none';
  if(channelId){
    const ch=c.channels.find(x=>x.id===channelId);
    document.getElementById('chm_channel').value=ch.channel||'insta';
    document.getElementById('chm_status').value=ch.status||'planning';
    document.getElementById('chm_owner').value=ch.owner||'';
    document.getElementById('chm_link').value=ch.link||'';
    document.getElementById('chm_memo').value=ch.memo||'';
  } else {
    document.getElementById('chm_channel').value='insta';
    document.getElementById('chm_status').value='planning';
    document.getElementById('chm_owner').value='';
    document.getElementById('chm_link').value='';
    document.getElementById('chm_memo').value='';
  }
  document.getElementById('channelModal').classList.add('open');
}
function saveChannelRow(){
  const c=contents.find(x=>x.id===editChannelContentId); if(!c) return;
  const row={
    id:editChannelId||Date.now(),
    channel:document.getElementById('chm_channel').value,
    status:document.getElementById('chm_status').value,
    owner:document.getElementById('chm_owner').value.trim(),
    link:document.getElementById('chm_link').value.trim(),
    memo:document.getElementById('chm_memo').value.trim(),
  };
  if(editChannelId){ const i=c.channels.findIndex(x=>x.id===editChannelId); if(i>=0) c.channels[i]=row; }
  else c.channels.push(row);
  save();closeModal('channelModal');renderCurrent();
  toast(editChannelId?'채널 수정됨':'채널 추가됨');
}
function deleteChannelRow(){
  if(!confirm('이 채널 행을 삭제할까요?')) return;
  const c=contents.find(x=>x.id===editChannelContentId); if(!c) return;
  c.channels=c.channels.filter(x=>x.id!==editChannelId);
  save();closeModal('channelModal');renderCurrent();toast('삭제됨');
}

function closeModal(id){ document.getElementById(id).classList.remove('open'); }

// ── CSV ──
function exportCSV(){
  const h=['제목','발행일','테마','연관 브랜드/제품','채널','상태','담당자','링크','메모'];
  const rows=[];
  contents.sort((a,b)=>a.date.localeCompare(b.date)).forEach(c=>{
    if(c.channels.length===0){ rows.push([c.title,c.date,THEME_LABELS[c.theme]||c.theme,c.brand,'','','','','']); }
    else c.channels.forEach(ch=>{ rows.push([c.title,c.date,THEME_LABELS[c.theme]||c.theme,c.brand||'',CH_LABELS[ch.channel]||ch.channel,ST_LABELS[ch.status]||ch.status,ch.owner,ch.link,ch.memo]); });
  });
  const csv=[h,...rows].map(r=>r.map(v=>'"'+String(v||'').replace(/"/g,'""')+'"').join(',')).join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'}));
  a.download='content_calendar_'+new Date().toISOString().slice(0,10)+'.csv';
  a.click();toast('CSV 다운로드 완료');
}

function toast(msg,ok=true){
  const el=document.getElementById('toast');
  el.textContent=msg;el.style.background=ok?'var(--text)':'var(--danger)';
  el.classList.add('show');clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),2800);
}

['contentModal','channelModal'].forEach(id=>{
  document.getElementById(id).addEventListener('click',function(e){if(e.target===this)closeModal(id);});
});

document.getElementById('filterMonth').value=new Date().toISOString().slice(0,7);
load();save();initCal();applyFilters();renderCalendar();
</script>
